{
  "description": "Second-pass vocal EQ strategy: selected-template residual EQ can reinforce severe covered problems, and can add psychoacoustic contrast boosts when extra presence/air makes body or mud feel smaller. Full-spectrum deviations remain diagnostic-first unless promoted by these policies.",
  "max_actions": 5,
  "presence_safety_boost_db": 1.0,
  "template_coverage": {
    "template_a": ["sub", "low", "lowmid", "mid", "nasal"],
    "template_b": ["upper", "harsh", "sib", "nasal"],
    "template_c": ["lowmid", "mid", "upper", "air"]
  },
  "template_coverage_details": {
    "template_a": [
      {"problem": "rumble / proximity cleanup", "bands": ["sub", "low"], "range_hz": [30, 200], "processors": ["template_a_vocal_proq3"]},
      {"problem": "muddy / boxy body", "bands": ["lowmid", "mid"], "range_hz": [200, 1200], "processors": ["template_a_vocal_proq3"]},
      {"problem": "nasal / honky correction", "bands": ["nasal"], "range_hz": [800, 1200], "processors": ["residual_vocal_eq"]}
    ],
    "template_b": [
      {"problem": "harsh / peaky upper-mid and sibilance", "bands": ["upper", "harsh", "sib"], "range_hz": [2500, 10000], "processors": ["f6_rta_mono", "sibilance_mono", "l1_limiter_mono"]},
      {"problem": "nasal edge inside the harsh template domain", "bands": ["nasal"], "range_hz": [800, 1200], "processors": ["residual_vocal_eq"]}
    ],
    "template_c": [
      {"problem": "presence-starved / dark vocal", "bands": ["upper", "air"], "range_hz": [2500, 16000], "processors": ["template_c_vocal_proq3", "oneknob_brighter_mono"]},
      {"problem": "heavy body / low-mid balance", "bands": ["lowmid", "mid"], "range_hz": [250, 1200], "processors": ["template_c_vocal_proq3"]}
    ]
  },
  "band_rules": {
    "sub": {"freq_hz": 55.0, "q": 0.75, "actions": ["cut"], "min_cut_db": 1.0, "max_cut_db": 4.0},
    "low": {"freq_hz": 130.0, "q": 0.75, "actions": ["cut"], "min_cut_db": 0.8, "max_cut_db": 3.0},
    "lowmid": {"freq_hz": 320.0, "q": 0.9, "actions": ["cut", "boost"], "min_cut_db": 0.8, "max_cut_db": 3.5, "min_boost_db": 0.5, "max_boost_db": 1.2},
    "mid": {"freq_hz": 900.0, "q": 0.9, "actions": ["cut", "boost"], "min_cut_db": 0.8, "max_cut_db": 2.8, "min_boost_db": 0.5, "max_boost_db": 1.2},
    "upper": {"freq_hz": 3600.0, "q": 0.85, "actions": ["cut", "boost"], "min_cut_db": 0.7, "max_cut_db": 2.5, "min_boost_db": 0.5, "max_boost_db": 1.8},
    "harsh": {"freq_hz": 6200.0, "q": 1.6, "actions": ["cut"], "min_cut_db": 0.7, "max_cut_db": 3.0},
    "sib": {"freq_hz": 8500.0, "q": 1.8, "actions": ["cut"], "min_cut_db": 0.7, "max_cut_db": 3.0},
    "air": {"freq_hz": 12500.0, "q": 0.7, "actions": ["boost"], "min_boost_db": 0.5, "max_boost_db": 1.5}
  },
  "feature_rule_map": {
    "lowmid_ratio_high": {"band": "lowmid", "type": "cut", "gain_db": -1.2, "freq_hz": 320.0, "q": 0.9},
    "very_high_lowmid": {"band": "lowmid", "type": "cut", "gain_db": -2.0, "freq_hz": 320.0, "q": 0.9, "strong": true},
    "mid_ratio_high": {"band": "mid", "type": "cut", "gain_db": -1.0, "freq_hz": 900.0, "q": 0.9},
    "body_to_presence_high": {"band": "lowmid", "type": "cut", "gain_db": -1.2, "freq_hz": 360.0, "q": 0.85},
    "strong_body_to_presence": {"band": "lowmid", "type": "cut", "gain_db": -2.0, "freq_hz": 360.0, "q": 0.85, "strong": true},
    "extreme_lowmid": {"band": "lowmid", "type": "cut", "gain_db": -2.4, "freq_hz": 300.0, "q": 0.8, "strong": true},
    "very_high_body_to_presence": {"band": "lowmid", "type": "cut", "gain_db": -2.2, "freq_hz": 330.0, "q": 0.85, "strong": true},
    "band_limited_highs": {"band": "upper", "type": "boost", "gain_db": 1.3, "freq_hz": 3600.0, "q": 0.85, "strong": true},
    "body_peak_spiky": {"band": "mid", "type": "cut", "gain_db": -1.4, "freq_hz": 1200.0, "q": 1.1},
    "very_spiky_body_peak": {"band": "mid", "type": "cut", "gain_db": -2.2, "freq_hz": 1200.0, "q": 1.1, "strong": true},
    "upper_ratio_high": {"band": "upper", "type": "cut", "gain_db": -1.0, "freq_hz": 3600.0, "q": 1.0},
    "upper_peak_spiky": {"band": "upper", "type": "cut", "gain_db": -1.3, "freq_hz": 3600.0, "q": 1.2},
    "harsh_ratio_high": {"band": "harsh", "type": "cut", "gain_db": -1.4, "freq_hz": 6200.0, "q": 1.5},
    "harsh_peak_spiky": {"band": "harsh", "type": "cut", "gain_db": -1.6, "freq_hz": 6200.0, "q": 1.7},
    "very_spiky_harsh": {"band": "harsh", "type": "cut", "gain_db": -2.4, "freq_hz": 6200.0, "q": 1.8, "strong": true},
    "very_high_harsh_ratio": {"band": "harsh", "type": "cut", "gain_db": -2.4, "freq_hz": 6200.0, "q": 1.6, "strong": true},
    "sib_ratio_high": {"band": "sib", "type": "cut", "gain_db": -1.4, "freq_hz": 8500.0, "q": 1.8},
    "very_high_sib_ratio": {"band": "sib", "type": "cut", "gain_db": -2.4, "freq_hz": 8500.0, "q": 2.0, "strong": true}
  },
  "covered_strong_policy": {
    "enabled": true,
    "gain_scale": 0.65,
    "max_abs_gain_db": 1.6,
    "reason": "Strong hits inside template coverage are not ignored; add a post-template corrective move so the base chain can be reinforced without changing its fixed DSP."
  },
  "perceptual_contrast_policy": {
    "enabled": true,
    "max_actions": 2,
    "template_c": {
      "trigger_body_to_presence": 8.0,
      "trigger_upper_ratio_below": 0.12,
      "presence_boost": {
        "band": "upper",
        "type": "boost",
        "freq_hz": 3400.0,
        "q": 0.75,
        "min_gain_db": 0.8,
        "max_gain_db": 1.6
      },
      "air_boost": {
        "band": "air",
        "type": "boost",
        "freq_hz": 11000.0,
        "q": 0.7,
        "min_gain_db": 0.4,
        "max_gain_db": 0.9,
        "max_harsh_ratio": 0.04,
        "max_sib_ratio": 0.018
      }
    }
  },
  "deviation_threshold_db": 1.5,
  "ratio_excess_threshold": 0.04,
  "diagnostic_only_sources": ["body_presence_diagnosis", "non_selected_template_hits"]
}
